# Hidden-artifact allowlist: deny dotfiles and dotfolders everywhere in the
# build context unless they are intentionally needed inside the image.
.*

# PocketBase binary (downloaded fresh during Docker build) and runtime data
pocketbase
pb_data/

# Project-specific files not needed in generic image
pb_hooks/
pb_migrations/
pb_public/
captain-definition
Makefile
docker-compose.yml

# Docs
README.md
